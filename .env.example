# ═══════════════════════════════════════════════════════════════
# FINESE SCHOOL - Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Flask ───────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=sqlite:///finese_school.db

# ── LLM Provider API Keys ───────────────────────────────────────
# Only set the keys for providers you want to use
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GOOGLE_API_KEY=AI-your-google-key-here
HF_TOKEN=hf-your-huggingface-token-here

# ── Ollama (Local Models) ───────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Rate Limiting ───────────────────────────────────────────────
RATELIMIT_DEFAULT=200 per day,50 per hour

# ── File Upload ─────────────────────────────────────────────────
MAX_CONTENT_LENGTH=50MB
