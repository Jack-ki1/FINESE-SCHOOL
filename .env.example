# FINESE SCHOOL doesn't require any of these to run — every lesson works
# with zero configuration. They're only here in case you want to self-host
# with a specific port or run behind a reverse proxy.

# Port Flask listens on (default 5000)
PORT=5000

# Set to 0 in production — 1 enables Flask's debugger, which is a
# security risk if the app is exposed to the internet.
FLASK_DEBUG=1

# Note: AI provider API keys are NEVER configured here. Each visitor
# pastes their own key into the sidebar in their browser, and it is sent
# directly with each question — this app never stores or reads provider
# keys from the server's environment.
